						path(d='M2.00138 1.8657H0L7.62618e-06 12.1429H2.00139L2.00138 1.8657Z' fill='black')
						path(d='M68.6591 5.42663L65.4081 1.77392H63.5075V10.2312H65.4919V4.8353L68.46 8.03219H68.8267L71.7438 4.8353V10.2312H73.7282V1.77392H71.8276L68.6591 5.42663Z' fill='black')
						path(d='M83.1822 1.77392L78.2637 7.27085V1.77392H76.2793V10.2312H78.0973L83.0158 4.73428V10.2312H85.0002V1.77392H83.1822Z' fill='black')
