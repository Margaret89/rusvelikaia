extends tmpl/_layout

block vars
	- var pageId = 'catalod-detail-white'
	- var bgWhite = true

block body
	.catalod-detail
		.catalod-detail__photo
			.catalod-detail-img
				-
					var list=[
						{img:'catalod-detail1.jpg'},
						{img:'catalod-detail2.jpg'},
						{img:'catalod-detail3.jpg'},
						{img:'catalod-detail4.jpg'},
					]
				each item in list
					a(href="/upload/"+item.img, data-fancybox="images").catalod-detail-img__item
						img(src="/upload/"+item.img, alt="")

		.catalod-detail__main
			ul.bredcrumb(itemscope="", itemtype="https://schema.org/BreadcrumbList")
				-
					var list=[
						{text:'Магазин подарков'},
						{text:'Подарки для интерьера'},
						{text:'Декоративные тарелки'},
					]
				each item in list
					li.bredcrumb__item(itemprop="itemListElement", itemscope="", itemtype="https://schema.org/ListItem")
						a(href="#", itemprop="item").bredcrumb__link
							span(itemprop="name")= item.text
							meta(itemprop="position", content="1")

			h1 Тарелка формы Тюльпан «Вьюнок». ИФЗ 18 см.

			.catalod-detail__article
				span Артикул: 0031220

			.catalod-detail__price
				.catalod-detail-price
					.catalod-detail-price__top
