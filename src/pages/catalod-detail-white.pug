			.catalog-deatail-tags
				h3 С этим товаром часто смотрят:

				.tags
					-
						var list=[
							{text:'Декоративные тарелки из фарфора'},
							{text:'Декоративные тарелки Женщине'},
							{text:'Декоративные тарелки Бабушке'},
							{text:'Декоративные тарелки Матери'},
							{text:'Декоративные тарелки Императорского фарфора'},
							{text:'Декоративные тарелки Тюльпан'},
						]
					each item in list
						a(href="#").tags__item= item.text