				.doljami__text 4 платежа по 475 ₽

				.doljami__icon
					+svg('ic-info','ic-info', '16', '16')

			.catalod-detail__action
				a(href="#").btn В корзину
				a(href="#").btn.btn_border Быстрая покупка

				.btn-wish
					.btn-wish__icon
						+svg('ic-heart-full','ic-heart-full', '23', '20')

					.btn-wish__label
						|Добавить 
						br
						|в избранное

			.catalod-detail__split
				img(src="/upload/yandex-split-white.png", alt="")

			.catalod-detail__desc
				.more-text.js-more-text
					.more-text__content.js-more-text-content(data-max-lines="3")
						p Декоративная тарелка с рисунком на лицевой поверхности 100% гармонизирует пространство.
							br
							|Вот почему расписная тарелка используется для украшения жилья с незапамятных времен.
							br
							|Декоративная тарелка «Вьюнок» представлена в Галерее как образец современного фарфорового промысла Санкт-Петербурга.

						p  Посуда ручной работы, сделанная в городе на Неве, продается в Галерее подарков в  комплектах, сервизах и поштучно. Вы можете купить  образцы посуды, оценить их качество и собрать набор нужной комплектации. Плоский корпус этой тарелки оформлен  из «русского белого золота» - твердого. не пористого фарфора  в соответствии с формой «Тюльпан».  Оформление поверхности  выполнено в технике ручной росписи с использованием экокраски -  окиси кобальта, приобретающей после обжига в печи синий цвет. А также  супер-краски на основе золота.
						p Посуда и элементы декора Императорского фарфорового завода сделаны в Санкт-Петербурге. Каждый образец посуды оформляется из «русского белого золота» - фарфора того или иного сорта и расписывается вручную. Уникальная рецептура каждого сорта фарфора разработана ученым Дмитрием Виноградовым еще в 18 веке для Елизаветинской порцелиновой мануфактуры, так раньше назывался Императорский фарфоровый завод.
						p Для декора образцов посуды используются необычные краски - такие, например,  как окись кобальта (черная краска, которая приобретает синий цвет после обжига в печи при сверхвысоких температурах) и супер-краска, которая готовится на основе жидкого золота. Роспись осуществляется вручную в подглазурных и надглазурных техниках, а также в технике деколь, которая предполагает нанесение рисунка на поверхность фарфора с листа бумаги.Основная роспись на корпусе посуды защищена слоями прозрачной стеклянной глазури.
						p Авторская работа, декоративная тарелка «Вьюнок» (форма «Тюльпан») ЛФЗ - Ваш отличный выбор.Вариант практичного подарка  на  общий или личный праздник.
						p Изделие Императорского фарфорового завода (ИФЗ/ЛФЗ) 

						p Форма: Тюльпан
							br
							|Рисунок: «Вьюнок»
							br
							|Автор рисунка: Славина Н.П.
							br
							|Эксклюзивная авторская работа.

					span.more-text__link.js-more-text-btn(data-text="Свернуть")
						span.js-more-text-btn-text Читать полностью 
						+svg('ic-arr-down','ic-arr-down', '16', '7')


			.catalog-detail-props
				-
					var list=[
						{label:'Материал:', value:'Фарфор'},
						{label:'Диаметр:', value:'180 мм'},
					]
				each item in list
					.catalog-detail-props__item
						.catalog-detail-props__label= item.label
						.catalog-detail-props__val= item.value

			.catalog-detail-info
				.catalog-detail-info__icon
					+svg('ic-map','ic-map', '35', '35')

				.catalog-detail-info__text В наличии 7 шт. ул. Верхняя Сыромятническая 2

			.share
				.share__label Поделиться: 

				.share__list
					a(href="#").share__item.share__item_vk
						+svg('ic-vk-square','ic-vk-square', '32', '32')

					a(href="#").share__item.share__item_ok
						+svg('ic-ok-square','ic-ok-square', '32', '32')

			.catalog-detail-brand
				.catalog-detail-brand__img
					img(src="/upload/rus-farfor.png", alt="")

				.catalog-detail-brand__content
					.catalog-detail-brand__title Императорский фарфор

					.catalog-detail-brand__link
						a(href="#") История бренда

					.catalog-detail-brand__link
						a(href="#") Все товары бренда | 124 шт.

			.catalog-other
				h2 Рекомендуем

				.catalog-list
					-
						var list=[
							{img:'cup1.png', prop:'Объем 230 мл', price:'4 200', title:'Набор бокалов для шампанского 230 мл «Азур». ИФЗ', article:'Артикул: 400103'},
							{img:'cup2.png', prop:'Объем 250 мл', price:'2 850', title:'Чайная пара 250 мл «Роузи».  Форма Весенняя-2. ИФЗ', article:'Артикул: 400047'},
							{img:'cup3.png', prop:'Объем 180 мл', price:'3 600', title:'Кофейная пара 180 мл «Год лошади». Форма Ландыш. ИФЗ', article:'Артикул: 400150'},
							{img:'horse.png', prop:'Высота 140 мм', price:'37 450', title:'Символ 2026 года. Статуэтка из хрусталя «Лошадь». Asfour Crystal покрытие Aura', article:'Артикул: 712024310'},
						]
					each item in list
						.catalog-item
							.catalog-item__top
								.catalog-item__prop= item.prop
								.catalog-item__price= item.price
									| 
									|&#8381;

							a(href="#").catalog-item__img-wrap
								.catalog-item__img
									img(src="/upload/"+item.img, alt="")
								
							.catalog-item__title
								a(href="#")= item.title

							.catalog-item__article= item.article

