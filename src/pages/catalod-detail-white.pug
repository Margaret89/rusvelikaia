							span.catalod-detail-price__old-val 6800
							| 
							span.catalod-detail-price__curency &#8381;

						.catalod-detail-price__sale -26%

						.catalod-detail-price__bank
							img(src="/upload/logo_tbank.svg", alt="")
					
					.catalod-detail-price__val 2600 
						span.catalod-detail-price__curency &#8381;

				.exclusive
					.exclusive__icon
						+svg('ic-diamond','ic-diamond', '24', '24')

					.exclusive__title эксклюзив
					.exclusive__text в единственном экземпляре

