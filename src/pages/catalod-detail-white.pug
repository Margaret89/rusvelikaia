						path(d='M43.5978 3.46538C43.4763 6.374 42.8691 8.25148 41.6802 8.25148H41.3826V10.2817L41.6996 10.299C44.0835 10.4333 45.4012 8.31924 45.6174 3.70191H48.753V10.2312H50.7338V1.77392H43.6646L43.5978 3.46538Z' fill='black')
						path(d='M36.1279 1.65576C33.444 1.65576 31.513 3.53324 31.513 6.00206C31.513 8.55587 33.614 10.3668 36.1279 10.3668C38.7462 10.3668 40.7804 8.45486 40.7804 6.00206C40.7804 3.54926 38.7462 1.65576 36.1279 1.65576ZM36.1279 8.33659C34.6111 8.33659 33.5776 7.33871 33.5776 6.00206C33.5776 4.63214 34.6123 3.66137 36.1279 3.66137C37.6435 3.66137 38.7122 4.67649 38.7122 6.00206C38.7122 7.32763 37.6289 8.33659 36.1279 8.33659Z' fill='black')
