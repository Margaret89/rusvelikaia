				.catalog-list
					-
						var list=[
							{img:'pic1.png', prop:'Высота 30 мм', price:'11 660', title:'Декоративная тарелка «Зима. Утенок». Форма Эллипс. ИФЗ', article:'Артикул: 0074240'},
							{img:'pic2.png', prop:'Высота 30 мм', price:'3 600', title:'Тарелка декоративная «Красный конь». Форма Эллипс. ИФЗ', article:'Артикул: 400147'},
							{img:'pic3.png', prop:'Высота 30 мм', price:'11 660', title:'Декоративная тарелка «Зима. Мальчик». Форма Эллипс. ИФЗ', article:'Артикул: 400150'},
							{img:'pic4.png', prop:'Диаметр 275 мм', price:'4 200', title:'Тарелка декоративная «Маленький Принц. Цитаты» ЛФЗ', article:'Артикул: 712024310'},
